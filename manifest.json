{
  "manifest_version": 3,
  "name": "GLM Coding 自动抢购助手",
  "description": "在每天 CST 10:00 自动尝试购买 GLM Coding（Lite/Pro/Max）。本扩展仅用于个人使用，请遵守平台 ToS。",
  "version": "1.2.0",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://bigmodel.cn/glm-coding*",
    "https://bigmodel.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
